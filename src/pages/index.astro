---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import Projects from '../components/Projects.astro';
import Contact from '../components/Contact.astro';
import { useTranslations } from '../i18n/utils';

const t = useTranslations('de');
---

<Layout title={t('site.title')} description={t('site.description')} lang="de">
  <Hero lang="de" />

  <Services lang="de" />

  <Projects lang="de" />

    {/* About Section */}
    <section id="about" class="py-20 px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">{t('nav.about')}</h2>
        <p class="text-lg text-gray-600">Über mich wird in einem zukünftigen Slice hinzugefügt.</p>
      </div>
    </section>

  <Contact lang="de" />
</Layout>
