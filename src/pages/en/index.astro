---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Services from '../../components/Services.astro';
import Projects from '../../components/Projects.astro';
import Contact from '../../components/Contact.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('en');
---

<Layout title={t('site.title')} description={t('site.description')} lang="en">
  <Hero lang="en" />

  <Services lang="en" />

  <Projects lang="en" />

    {/* About Section */}
    <section id="about" class="py-20 px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">{t('nav.about')}</h2>
        <p class="text-lg text-gray-600">About will be added in a future slice.</p>
      </div>
    </section>

  <Contact lang="en" />
</Layout>
