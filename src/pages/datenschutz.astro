---
import Layout from '../layouts/Layout.astro';
import { useTranslations } from '../i18n/utils';

const t = useTranslations('de');
const title = `${t('datenschutz.title')} | Siam IT`;
const description = t('site.description');
---

<Layout title={title} description={description} lang="de">
  <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6 lg:px-8">
    <h1 class="text-3xl font-bold text-gray-900 mb-8">{t('datenschutz.title')}</h1>

    <section class="space-y-8 text-gray-700">
      <p class="text-lg">{t('datenschutz.intro')}</p>

      <div>
        <h2 class="text-xl font-semibold text-gray-900 mb-3">{t('datenschutz.responsible.title')}</h2>
        <p>Siam IT - Siam Ngamkam</p>
        <p>Kontaktdaten siehe <a href="/impressum" class="text-blue-700 hover:underline focus:outline-none focus:ring-2 focus:ring-blue-500 rounded">Impressum</a></p>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-gray-900 mb-3">{t('datenschutz.data.title')}</h2>
        <p>{t('datenschutz.data.content')}</p>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-gray-900 mb-3">{t('datenschutz.cookies.title')}</h2>
        <p>{t('datenschutz.cookies.content')}</p>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-gray-900 mb-3">{t('datenschutz.rights.title')}</h2>
        <p>{t('datenschutz.rights.content')}</p>
      </div>
    </section>
  </div>
</Layout>
