---
import Layout from '../layouts/Layout.astro';
import { useTranslations } from '../i18n/utils';

const t = useTranslations('de');
const title = `${t('legal.impressum.title')} | Siam IT`;
const description = t('site.description');
---

<Layout title={title} description={description} lang="de">
  <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6 lg:px-8">
    <h1 class="text-3xl font-bold text-gray-900 mb-8">{t('legal.impressum.title')}</h1>

    <section class="space-y-6 text-gray-700">
      <div>
        <h2 class="text-lg font-semibold text-gray-900 mb-2">{t('legal.impressum.responsible')}</h2>
        <p>Siam IT</p>
        <p>Siam Ngamkam</p>
      </div>

      <div>
        <h2 class="text-lg font-semibold text-gray-900 mb-2">{t('legal.impressum.address')}</h2>
        <p>[Straße und Hausnummer]</p>
        <p>[PLZ Ort]</p>
        <p>Deutschland</p>
      </div>

      <div>
        <h2 class="text-lg font-semibold text-gray-900 mb-2">{t('legal.impressum.contact')}</h2>
        <p>Telefon: [Telefonnummer]</p>
        <p>E-Mail: [E-Mail-Adresse]</p>
      </div>

      <div>
        <h2 class="text-lg font-semibold text-gray-900 mb-2">{t('legal.impressum.vat')}</h2>
        <p>[USt-IdNr. falls vorhanden]</p>
      </div>

      <div class="border-t border-gray-200 pt-6 mt-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-2">{t('legal.disclaimer.title')}</h2>
        <p class="text-sm">{t('legal.disclaimer.content')}</p>
      </div>
    </section>
  </div>
</Layout>
