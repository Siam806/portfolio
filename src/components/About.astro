---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const techStack = [
  { name: 'TypeScript', icon: 'TS' },
  { name: 'Astro', icon: '🚀' },
  { name: 'Node.js', icon: 'N' },
  { name: 'React', icon: '⚛' },
  { name: 'Tailwind CSS', icon: 'TW' },
  { name: 'Python', icon: 'Py' },
  { name: 'PostgreSQL', icon: 'PG' },
  { name: 'Git', icon: 'G' },
] as const;
---

<section id="about" class="py-20 px-4 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <h2 class="text-3xl font-bold text-gray-900 mb-4">{t('about.title')}</h2>

    <div class="grid gap-12 lg:grid-cols-2">
      <div>
        <p class="text-lg leading-relaxed text-gray-600">{t('about.bio')}</p>
      </div>

      <div>
        <h3 class="mb-6 text-xl font-semibold text-gray-900">{t('about.techstack')}</h3>
        <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4">
          {techStack.map((tech) => (
            <div class="flex flex-col items-center rounded-xl border border-gray-200 bg-white p-4 shadow-sm transition-shadow hover:shadow-md">
              <span class="mb-2 flex h-10 w-10 items-center justify-center rounded-lg bg-blue-100 text-sm font-bold text-blue-700">
                {tech.icon}
              </span>
              <span class="text-sm font-medium text-gray-700">{tech.name}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
