---
import { getCollection } from 'astro:content';
import { useTranslations, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const services = await getCollection('services');

function getTitle(service: (typeof services)[number]): string {
  return lang === 'de' ? service.data.titleDe : service.data.titleEn;
}

function getDescription(service: (typeof services)[number]): string {
  return lang === 'de' ? service.data.descriptionDe : service.data.descriptionEn;
}
---

<section id="services" class="py-20 px-4 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <h2 class="text-3xl font-bold text-gray-900 mb-4">{t('nav.services')}</h2>
    <p class="mb-12 text-lg text-gray-600">{t('services.subtitle')}</p>

    <div class="grid gap-8 sm:grid-cols-2">
      {services.map((service) => (
        <div class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm transition-shadow hover:shadow-md">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-blue-100 text-blue-700">
            {service.data.icon === 'Globe' && (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10" />
                <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10A15.3 15.3 0 0 1 12 2z" />
              </svg>
            )}
            {service.data.icon === 'Database' && (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <ellipse cx="12" cy="5" rx="9" ry="3" />
                <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3" />
                <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5" />
              </svg>
            )}
          </div>
          <h3 class="mb-2 text-xl font-semibold text-gray-900">{getTitle(service)}</h3>
          <p class="text-gray-600">{getDescription(service)}</p>
        </div>
      ))}
    </div>
  </div>
</section>
