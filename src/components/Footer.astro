---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const currentYear = new Date().getFullYear();

const impressumPath = lang === 'de' ? '/impressum' : '/en/impressum';
const datenschutzPath = lang === 'de' ? '/datenschutz' : '/en/datenschutz';
---

<footer class="bg-gray-900 text-gray-300">
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
      {/* Copyright */}
      <p class="text-sm text-gray-400">
        {t('footer.copyright', { year: currentYear })}
      </p>

      {/* Legal Links */}
      <nav class="flex items-center gap-6" aria-label="Legal navigation">
        <a
          href={impressumPath}
          class="text-sm text-gray-400 hover:text-white transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 focus:ring-offset-gray-900 rounded px-2 py-1"
        >
          {t('footer.impressum')}
        </a>
        <a
          href={datenschutzPath}
          class="text-sm text-gray-400 hover:text-white transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 focus:ring-offset-gray-900 rounded px-2 py-1"
        >
          {t('footer.datenschutz')}
        </a>
      </nav>
    </div>
  </div>
</footer>
